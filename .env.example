# Obrigatório
DEEPSEEK_API_KEY=coloque_sua_chave_aqui

# Modelo configurável. deepseek-chat é o padrão mais compatível.
DEEPSEEK_MODEL=deepseek-chat

# Persistência
AHO_DB_PATH=./data/aho.db
AHO_SKILLS_DIR=./skills

# API
AHO_HOST=127.0.0.1
AHO_PORT=7777
AHO_RELOAD=false

# Agente
AHO_HISTORY_RUNS=3
AHO_SESSION_SUMMARIES=true
AHO_MEMORY=true
AHO_STREAM=true
AHO_STREAM_EVENTS=true
AHO_DEBUG=false
AHO_TELEMETRY=false
AHO_LOG_LEVEL=INFO
